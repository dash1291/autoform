# Database
DATABASE_URL=postgresql://username:password@localhost:5432/autoform

# Security
SECRET_KEY=your-secret-key-here-generate-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# AWS
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key  # Optional, can use AWS profile
# AWS_SECRET_ACCESS_KEY=your-aws-secret  # Optional, can use AWS profile

# Application
APP_NAME=AutoForm Backend
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Redis
REDIS_URL=redis://localhost:6379/0