# Database
DATABASE_URL=postgresql://username:password@localhost:5432/autoform

# Security
SECRET_KEY=your-secret-key-here-generate-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# For team AWS credential encryption
SECRET_KEY_BASE=your-secret-key-for-encryption
# Base64-encoded 32-byte key for encrypting team AWS credentials
ENCRYPTION_KEY=XKD7nXtn8h43l9Ti8MN1Ve3jnsB0PlELf5o0TCWL9JU=

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# AWS
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key  # Optional, can use AWS profile
# AWS_SECRET_ACCESS_KEY=your-aws-secret  # Optional, can use AWS profile

# Application
APP_NAME=AutoForm Backend
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
WEBHOOK_BASE_URL=http://localhost:8000  # For production, use your actual domain

# Redis
REDIS_URL=redis://localhost:6379/0

# LocalStack Configuration (for local development)
# Only set USE_LOCALSTACK=true to enable, other values are optional
USE_LOCALSTACK=false
# LOCALSTACK_HOST=localhost  # Optional, defaults to localhost
# LOCALSTACK_PORT=4566       # Optional, defaults to 4566