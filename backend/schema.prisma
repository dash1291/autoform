generator client {
  provider  = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String         @id @default(cuid())
  name            String?
  email           String?        @unique
  emailVerified   DateTime?
  image           String?
  githubId        String?        @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  accounts        Account[]
  projects        Project[]
  sessions        Session[]
  ownedTeams      Team[]         @relation("TeamOwner")
  teamMemberships TeamMember[]
  awsConfig       UserAWSConfig?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Webhook {
  id          String    @id @default(cuid())
  gitRepoUrl  String    @unique
  secret      String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id                 String                @id @default(cuid())
  name               String
  gitRepoUrl         String
  branch             String                @default("main")
  userId             String
  teamId             String?
  status             ProjectStatus         @default(CREATED)
  ecsClusterArn      String?
  ecsServiceArn      String?
  albArn             String?
  domain             String?
  existingVpcId      String?
  existingSubnetIds  String?
  existingClusterArn String?
  cpu                Int                   @default(256)
  memory             Int                   @default(512)
  diskSize           Int                   @default(21)
  subdirectory       String?
  port               Int                   @default(3000)
  healthCheckPath    String                @default("/health")
  autoDeployEnabled  Boolean               @default(false)
  webhookId          String?
  webhookConfigured  Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  secretsArn         String?
  deployments        Deployment[]
  environments       Environment[]
  environmentVars    EnvironmentVariable[]
  webhook            Webhook?              @relation(fields: [webhookId], references: [id])
  team               Team?                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deployment {
  id            String           @id @default(cuid())
  projectId     String
  environmentId String?
  status        DeploymentStatus @default(PENDING)
  imageTag      String
  commitSha     String
  logs          String?
  details       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment   Environment?     @relation(fields: [environmentId], references: [id], onDelete: Cascade)
}

model Environment {
  id                   String                @id @default(cuid())
  name                 String
  projectId            String
  teamAwsConfigId      String
  status               EnvironmentStatus     @default(CREATED)
  branch               String                @default("main")
  cpu                  Int                   @default(256)
  memory               Int                   @default(512)
  diskSize             Int                   @default(21)
  existingVpcId        String?
  existingSubnetIds    String?
  existingClusterArn   String?
  ecsClusterArn        String?
  ecsServiceArn        String?
  albArn               String?
  albName              String?
  domain               String?
  taskDefinitionArn    String?
  secretsArn           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  teamAwsConfig        TeamAwsConfig         @relation(fields: [teamAwsConfigId], references: [id], onDelete: Cascade)
  deployments          Deployment[]
  environmentVariables EnvironmentVariable[]

  @@unique([projectId, name])
}

model EnvironmentVariable {
  id            String      @id @default(cuid())
  environmentId String
  projectId     String
  key           String
  value         String?
  isSecret      Boolean     @default(false)
  secretKey     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
}

model Team {
  id          String          @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  projects    Project[]
  owner       User            @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  awsConfigs  TeamAwsConfig[]
  members     TeamMember[]
}

model TeamMember {
  id       String         @id @default(cuid())
  teamId   String
  userId   String
  role     TeamMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())
  team     Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamAwsConfig {
  id                 String        @id @default(cuid())
  teamId             String
  name               String
  awsAccessKeyId     String
  awsSecretAccessKey String
  awsRegion          String        @default("us-east-1")
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  team               Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  environments       Environment[]

  @@unique([teamId, name])
}

model UserAWSConfig {
  id                 String   @id @default(cuid())
  userId             String   @unique
  awsAccessKeyId     String
  awsSecretAccessKey String
  awsRegion          String   @default("us-east-1")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProjectStatus {
  CREATED
  CLONING
  BUILDING
  DEPLOYING
  DEPLOYED
  FAILED
}

enum DeploymentStatus {
  PENDING
  BUILDING
  PUSHING
  PROVISIONING
  DEPLOYING
  SUCCESS
  FAILED
}

enum TeamMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum EnvironmentStatus {
  CREATED
  PROVISIONING
  DEPLOYING
  DEPLOYED
  FAILED
  DELETING
}