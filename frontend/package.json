{
  "name": "autoform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "docker:build": "docker build -t autoform .",
    "docker:run": "docker run -p 3000:3000 --env-file .env autoform",
    "docker:dev": "docker build -t autoform . && docker run -p 3000:3000 --env-file .env autoform"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "aws-sdk": "^2.1692.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.511.0",
    "next": "14.0.4",
    "next-auth": "^4.24.5",
    "next-themes": "^0.4.6",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
