{
  "name": "autoform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "docker:build": "docker build -t autoform .",
    "docker:run": "docker run -p 3000:3000 --env-file .env autoform",
    "docker:dev": "docker build -t autoform . && docker run -p 3000:3000 --env-file .env autoform"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.7.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "aws-sdk": "^2.1692.0",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "next": "14.0.4",
    "next-auth": "^4.24.5",
    "postcss": "^8",
    "prisma": "^5.7.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "@types/node": "^20.10.5"
  }
}
